{
    "height": 30,
    "spacing": 4,
    "margin-top": 5,
    "margin-left": 5,
    "margin-right": 5,
    "margin-bottom": 5,
    "reload_style_on_change": true,
    "layer": "top",

    // Modules Layout
    "modules-left": [
        "custom/arch",
        "sway/workspaces"
        // "custom/media"
    ],
    "modules-center": [
        "custom/media"
    ],
    "modules-right": [
        "custom/headsetVolume",
        "tray",
        {{- if eq .chezmoi.hostname "thinkpadofmiquella" }}
        "bluetooth",
        {{- end }}
        "network",
        "clock",
        {{- if eq .chezmoi.hostname "thinkpadofmiquella" }}
        "battery",
        {{- end }}
        "group/volume",
        "custom/power"
    ],

    // Module Configurations
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "escape": true,
        "hide-empty-text": true,
        "on-click": "swayosd-client --player 'Feishin'  --playerctl play-pause",
        "exec": "/usr/bin/python3 $HOME/.config/waybar/scripts/mediaplayer.py --player Feishin 2> /dev/null"
    },

    "bluetooth": {
        "format": "",
        "format-disabled": "", // an empty format will hide the module
        "format-connected": "οäî {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "$HOME/.config/sway/scripts/fuzzel/bluetooth_menu.sh"

    },



    "group/volume": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 500
        },
        "modules": [
            "pulseaudio",
            "pulseaudio/slider"
        ]
    },

    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },



    "custom/power": {
        "format": "σΑΛÜ",
        "on-click": "$HOME/.config/sway/scripts/fuzzel/powermenu.sh",
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "default": "ο³ë ",
            "1:Browser": "οâΪ ",
            "2:Code": "νΪ³ ",
            "3:Music": "νΑ¦ ",
            "4:Social": "σ±΄ä ",
            "5:Kitty": "νΣÖ ",
            "6:Games": "σΑä¥ ",
            "99": "σΑΗΖ "

        }
    },

    "sway/window": {
        "format": "{app_id}",
        "max-length": 50,
        "all-outputs": true,
        "offscreen-css": true,
        "offscreen-css-text": "(inactive)",
        "rewrite": {
            "(.*) - Mozilla Firefox": "ο²§ $1",
            "(.*) - fish": "> [$1]"
        }
    },

    "custom/arch": {
        "format": "<span size='large' color='#179299'>σΑΘ΅ </span>",
        "on-click": "waypaper",
        "tooltip-format": "btw"
    },

    "tray": {
        "icon-size": 21,
        "spacing": 7,
        "show-passive-items": true
    },

    "pulseaudio": {
        "format": "{icon}",
        "tooltip-format": "{volume}%",
        "format-muted": "νΜ® ",
        "format-icons": {
            "default": ["οÄß ", "οÄ® "]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pactl -- set-sink-volume 0 100%"
    },

    "clock": {
        "format": "<span color='#b4befe'>οÄ½  </span>{:%H:%M}",
        "tooltip": true,
        "tooltip-format": "{:%d/%m/%Y}",
        "on-click": "gnome-calendar"
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-icons": {
            "default": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
            "charging": ["σΑ²³"],
        },

        "max-length": 25
    },

    "network": {
        "format-wifi": "ο΅Ϊ   {signalStrength}%",
        "format-ethernet": "σΑàÄ   Wired",
        "format-disconnected": "σΑΛ°   Offline",

        // Detailed Tooltips
        "tooltip-format-wifi": "SSID: {essid}\nIP: {ipaddr}\nFreq: {frequency} MHz\nσΑ΅ö {bandwidthDownBytes} | σΑï£ {bandwidthUpBytes}",
        "tooltip-format-ethernet": "Interface: {ifname}\nIP: {ipaddr}\nGateway: {gwaddr}\nσΑ΅ö {bandwidthDownBytes} | σΑï£ {bandwidthUpBytes}",
        "tooltip-format-disconnected": "No network connection",

        // General Settings
        "max-length": 10,
        "on-click": "$HOME/.config/sway/scripts/fuzzel/network_manager.sh",
    },
}
